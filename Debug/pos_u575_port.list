/* 当前阶段日志统一走 USART1。后续做双 UART 时，日志仍建议保留在 UART1。 */
static osMutexId_t g_uart1_log_mutex = NULL;

/* 绑定 UART1 日志发送互斥锁 */
void log_bind_uart1_mutex(osMutexId_t mutex_handle)
